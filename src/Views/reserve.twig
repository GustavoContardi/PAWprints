<?php
// Variables disponibles: $book (array|null), $errors (array|null), $old (array|null), $success (bool|null), $reserve (array|null)
$book    = $book ?? null;
$errors  = $errors ?? [];
$old     = $old ?? [];
$success = $success ?? false;
$reserve = $reserve ?? null;
?>

<h1>PAWprints</h1>
<h2>Datos de reserva</h2>

{% if success %}
    <div class="reserva-exito">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="reserva-exito-icono">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <p>¡Reserva enviada correctamente!<br><span>Nos pondremos en contacto a la brevedad.</span></p>

        <?php if ($reserve): ?>
        <div class="reserva-datos">
            <p><strong>Libro:</strong> <?= htmlspecialchars($reserve['book_title'] ?? ($book['title'] ?? '')) ?></p>
            <p><strong>Nombre:</strong> <?= htmlspecialchars($reserve['buyer_name']) ?></p>
            <p><strong>Teléfono:</strong> <?= htmlspecialchars($reserve['phone']) ?></p>
            <p><strong>Email:</strong> <?= htmlspecialchars($reserve['email']) ?></p>
            <p><strong>Copias:</strong> <?= (int)$reserve['copies'] ?></p>
            <p><strong>Fecha:</strong> <?= htmlspecialchars($reserve['created_at']) ?></p>
        </div>
        <?php endif; ?>

        <?php if ($book): ?>
            <a href="/book/<?= $book['id'] ?>" class="btn-link">Volver al libro</a>
        <?php else: ?>
            <a href="/catalogue" class="btn-link">Volver al catálogo</a>
        {% endif %}
    </div>
{% else %}

    {% if errors is not empty %}
        <div class="reserva-errores">
            <ul>
                {% for error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <form method="post" action="/reserve">
        <fieldset>
            <legend>Información de pedido</legend>

            <label for="nombre">Nombre entero</label>
            <input type="text" name="nombre" id="nombre"
                   placeholder="eg. Juan Perez"
                   maxlength="255"
                   value="{{ old.nombre ?? '' }}"
                   required>

            <label for="tel">Teléfono</label>
            <input type="text" name="telefono" id="tel"
                   placeholder="eg. +54 11 1234 5678"
                   maxlength="50"
                   value="{{ old.telefono ?? '' }}"
                   required>

            <label for="email">Correo electrónico</label>
            <input type="email" name="email" id="email"
                   placeholder="eg. juanperez@yahoo.com"
                   value="{{ old.email ?? '' }}"
                   required>

            <label for="busqueda">Libro a reservar</label>
            {% if book %}
                <input type="text" id="busqueda" name="libro"
                       value="{{ book.title }}"
                       readonly required>
                <input type="hidden" name="libro_id" value="{{ book.id }}">
            {% else %}
                <input type="text" id="busqueda" name="libro"
                       placeholder="Título del libro"
                       value="{{ old.libro ?? '' }}"
                       required>
                {% if old.libro_id is defined and old.libro_id is not empty %}
                    <input type="hidden" name="libro_id" value="{{ old.libro_id }}">
                {% endif %}
            {% endif %}

            <span class="reserva-copias-label">
                <label for="copias">Cantidad de copias</label>
                <output for="copias" id="copias-valor">{{ old.copias ?? '1' }}</output>
            </span>
            <input type="range" id="copias" name="copias"
                   min="1" max="100"
                   value="{{ old.copias ?? 1 }}" step="1"
                   oninput="document.getElementById('copias-valor').value = this.value">

            <button type="submit">Guardar reserva</button>
        </fieldset>
    </form>

{% endif %}
{% endblock %}
