<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/assets/img/image.png" type="image/png">
    <title>{% block title %}PAWprints{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('estilos/base.css') }}">
    <link rel="stylesheet" href="{{ asset('estilos/layout.css') }}">
    <link rel="stylesheet" href="{{ asset('estilos/components.css') }}">
    {% if styles is defined and styles is not empty %}
        {% for style in styles %}
            <link rel="stylesheet" href="{{ asset('estilos/' ~ style) }}">
        {% endfor %}
    {% endif %}
    {% block extra_styles %}{% endblock %}
    {% block microdata_head %}{% endblock %}
    <style>
        .nav-btn-logout {
            background: transparent;
            color: var(--color-white);
            font-family: var(--font);
            cursor: pointer;
            border: 1.5px solid rgba(255, 255, 255, 0.6);
            border-radius: var(--radius);
            padding: 0.3rem 0.85rem;
            font-size: 0.8125rem;
            font-weight: 500;
            transition: background 0.2s, border-color 0.2s;
        }
        .nav-btn-logout:hover {
            background: rgba(255, 255, 255, 0.15);
            border-color: var(--color-white);
        }
        @media (max-width: 899px) {
            .nav-logout-li {
                width: 100%;
                text-align: center;
            }
            .nav-btn-logout {
                display: inline-block;
                width: 50%;
                max-width: 300px;
                margin: 0.25rem auto;
                padding: 0.75rem 1rem;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <header>
        <a href="/"><img src="/assets/img/logo_PAWprints.svg" alt="Logo PAWprints"></a>
        <nav>
            <button id="menu-toggle" aria-label="Abrir menú" class="hamburger-btn"></button>
            <ul id="nav-menu">
                <li><a href="/catalogue">Catálogo</a></li>
                <li><a href="/special">Indispensables</a></li>
                <li><a href="/catalogue?order=popular">Más Vendidos</a></li>
                <li><a href="/about-us">Sobre nosotros</a></li>
                <li><a href="/contact">Contacto</a></li>
                {% if is_authenticated %}
                    <li><a href="/books/new">Cargar libro</a></li>
                    <li><a href="/admin/reserves">Pedidos</a></li>
                    <li class="nav-logout-li">
                        <form method="post" action="/logout" style="display: inline-block; margin: 0;">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
                            <button type="submit" class="nav-btn-logout">Cerrar sesión</button>
                        </form>
                    </li>
                {% else %}
                    <li><a href="/login" class="nav-btn">Acceso empleados</a></li>
                {% endif %}
            </ul>
        </nav>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer>
        <h3>Redes Sociales</h3>
        <address class="rs">
            <ul>
                <li><a href="https://www.x.com/pawprints">X</a></li>
                <li><a href="https://www.instagram.com/pawprints">Instagram</a></li>
                <li><a href="https://www.youtube.com/pawprints">YouTube</a></li>
            </ul>
        </address>
        <h3>Contacto</h3>
        <address>
            <p>+54 11 1234 5678</p>
        </address>
        <h3>Dirección</h3>
        <address>
            <p>Argentina, Buenos Aires</p>
            <p>Luján, Humberto Primo 666 (6700)</p>
            <p>2025-2026 PAWprints libros S.A.</p>
        </address>
    </footer>
    <script src="{{ asset('scripts/layout.js') }}"></script>
    {% block extra_scripts %}{% endblock %}
</body>
</html>
